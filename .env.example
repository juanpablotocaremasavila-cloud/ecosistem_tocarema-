# .env.example
# Copia este archivo a .env y rellena los valores con los que te proporciona Railway
# ------------------------------------------------------------
DB_HOST=your_mysql_host        # e.g., containers-us-west-123.railway.app
DB_PORT=3306                  # puerto proporcionado por Railway (usualmente 3306)
DB_USER=your_mysql_user        # usuario creado en Railway
DB_PASSWORD=your_mysql_pass    # contraseña del usuario
DB_NAME=your_mysql_database    # nombre de la base de datos
# ------------------------------------------------------------
# Opcional: otras variables de entorno para tu backend
API_PORT=8080
